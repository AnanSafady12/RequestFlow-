# .env.example
# This is a TEMPLATE — it shows which variables you need to set.
# Copy this file, rename it to .env, and fill in the real values.
# NEVER commit the real .env file to GitHub — only this example file.

# --- Database ---
# The credentials Docker will use to create the PostgreSQL database
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=requestflow_db

# The full connection string Prisma uses to connect to the database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/requestflow_db

# --- JWT (JSON Web Token) ---
# A long random string used to sign and verify login tokens
# You can generate one at: https://randomkeygen.com/
JWT_SECRET=your_super_secret_jwt_key_here

# How long a login token stays valid before the user has to log in again
JWT_EXPIRES_IN=7d

# --- Email (Gmail) ---
# The Gmail account we use to send verification codes to students
# You need to enable "App Passwords" in your Google account settings
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_FROM=RequestFlow <your_gmail_address@gmail.com>

# --- Server ---
# Which port the backend server listens on
PORT=3000

# The URL of the frontend app (used for CORS — allows the frontend to call the backend)
CLIENT_URL=http://localhost:5173

# --- Environment ---
# Set to "development" locally, "production" when deployed
NODE_ENV=development
