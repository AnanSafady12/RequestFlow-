# server/.env.example
# Copy this file, rename it to .env, and fill in your real values.
# This file is safe to commit — it has no real secrets.

# Full PostgreSQL connection string for Prisma
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/requestflow_db

# Database credentials (same as docker-compose)
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=requestflow_db

# JWT secret key — make this a long random string
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Gmail credentials for sending verification codes
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=RequestFlow <your_gmail@gmail.com>

# Server port
PORT=3000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Environment
NODE_ENV=development
